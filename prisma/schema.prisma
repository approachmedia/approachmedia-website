generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Portfolio Projects
model PortfolioProject {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  clientName        String
  industry          String
  exhibitionName    String
  locationCity      String
  locationCountry   String
  year              Int
  projectType       String
  servicesUsed      String[]
  shortDescription  String
  fullCaseStudy     String    @db.Text
  heroImage         String?
  galleryImages     String[]
  videoUrl          String?
  featured          Boolean   @default(false)
  seoTitle          String?
  seoDescription    String?
  schemaData        Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  enquiries         LeadEnquiry[]

  @@index([featured])
  @@index([industry])
  @@index([locationCountry])
}

// Blog Posts / Insights
model BlogPost {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  excerpt           String
  content           String    @db.Text
  author            String
  category          String
  tags              String[]
  featuredImage     String?
  publishedAt       DateTime
  status            String    @default("draft")
  seoTitle          String?
  seoDescription    String?
  canonicalUrl      String?
  schemaData        Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([publishedAt])
  @@index([category])
}

// Upcoming Exhibitions
model UpcomingExhibition {
  id                String    @id @default(cuid())
  eventName         String
  slug              String    @unique
  city              String
  country           String
  venue             String
  startDate         DateTime
  endDate           DateTime
  industryCategory  String
  eventWebsite      String?
  shortDescription  String
  planningNote      String?
  featured          Boolean   @default(false)
  seoTitle          String?
  seoDescription    String?
  schemaData        Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  enquiries         LeadEnquiry[]

  @@index([startDate])
  @@index([featured])
  @@index([country])
}

// Clients
model Client {
  id                String    @id @default(cuid())
  name              String
  logo              String?
  industry          String?
  testimonialId     String?
  websiteUrl        String?
  featured          Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([featured])
  @@index([industry])
}

// Testimonials
model Testimonial {
  id                String    @id @default(cuid())
  clientName        String
  designation       String
  company           String
  quote             String    @db.Text
  rating            Int?
  image             String?
  relatedProjectId  String?
  featured          Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([featured])
}

// Lead Enquiries
model LeadEnquiry {
  id                String    @id @default(cuid())
  name              String
  company           String?
  email             String
  phone             String?
  country           String?
  city              String?
  exhibitionName    String?
  projectId         String?
  project           PortfolioProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  exhibitionId      String?
  exhibition        UpcomingExhibition? @relation(fields: [exhibitionId], references: [id], onDelete: SetNull)
  stallSize         String?
  timeline          String?
  budgetRange       String?
  message           String?   @db.Text
  sourcePage        String?
  status            String    @default("new")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

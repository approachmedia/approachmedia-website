# Copy this file to .env.local for local development
# Never commit .env.local to git

# ─── Database ───────────────────────────────────────────────
# Get this from Railway > your project > PostgreSQL service > Variables
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://approachmedia.in"

# ─── Admin Auth (simple secret for Step 3 admin panel) ──────
ADMIN_SECRET="change-this-to-a-long-random-string"
